# ============================================================
# 법률 분쟁 사건 자동 발굴 시스템 - 환경 변수 설정 (템플릿)
# 이 파일을 복사하여 .env로 저장한 후 실제 값을 입력하세요.
# cp .env.example .env
# ============================================================

# ---- Django ----
DJANGO_SECRET_KEY=your-django-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ---- 네이버 API ----
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret

# ---- Gemini API (기본 LLM) ----
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# ---- OpenAI API (선택사항 — Gemini 실패 시 폴백) ----
OPENAI_API_KEY=
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=8192

# ---- Redis / Celery ----
REDIS_URL=redis://localhost:6379/0

# ---- 크롤링 설정 ----
CRAWL_INTERVAL_MINUTES=60
NEWS_KEYWORDS=소송,손해배상,집단소송,공동소송,피해자,피해보상,피해구제

# ---- Google Sheets (선택사항) ----
GOOGLE_SHEETS_CREDENTIALS_FILE=credentials/google_service_account.json
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here

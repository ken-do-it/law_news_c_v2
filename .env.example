# ============================================================
# 법률 분쟁 사건 자동 발굴 시스템 - 환경 변수 설정 (템플릿)
# 이 파일을 복사하여 .env로 저장한 후 실제 값을 입력하세요.
# cp .env.example .env
# ============================================================

# ---- Django ----
DJANGO_SECRET_KEY=your-django-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ---- 네이버 API ----
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret

# ---- OpenAI API ----
OPENAI_API_KEY=sk-your-openai-api-key-here
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1000

# ---- Gemini API ----
GEMINI_API_KEY=your-gemini-api-key-here

# ---- Redis / Celery ----
REDIS_URL=redis://localhost:6379/0

# ---- 크롤링 설정 ----
CRAWL_INTERVAL_MINUTES=60
NEWS_KEYWORDS=소송,손해배상,집단소송,공동소송,피해자,피해보상,피해구제

# ---- Google Sheets (선택사항) ----
GOOGLE_SHEETS_CREDENTIALS_FILE=credentials/google_service_account.json
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here

# ---- Runserver 자동 수집/분석 (APScheduler) ----
# True면 runserver 시작 즉시 1회 + 주기 실행
ENABLE_PIPELINE_ON_RUNSERVER=False
# 재실행 주기(분)
PIPELINE_INTERVAL_MINUTES=60
# True: Celery delay() 사용, False: 동기 함수 직접 실행
USE_CELERY_PIPELINE=False
